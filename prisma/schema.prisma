generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
}

enum SprintStatus {
  PLANNED   @map("planned")
  ACTIVE    @map("active")
  COMPLETED @map("completed")
}

enum IssueStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  DONE        @map("done")
}

enum IssuePriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")
}

enum IssueType {
  TASK    @map("task")
  SUBTASK @map("subtask")
}

enum BackupType {
  MANUAL
  SCHEDULED
  PRE_RESTORE
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  RESTORED
  DELETED
}

enum BackupFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  jiraAccountId  String?           @unique
  name           String
  passwordHash   String
  isActive       Boolean           @default(true)
  image          String?
  memberships    ProjectMember[]
  assignedIssues Issue[]           @relation("IssueAssignee")
  reportedIssues Issue[]           @relation("IssueReporter")
  comments       IssueComment[]
  attachments    IssueAttachment[]
  worklogs       IssueWorklog[]
  auditLogs      AuditLog[]        @relation("AuditUser")
  backupRecords  BackupRecord[]    @relation("BackupGeneratedBy")
  backupLogs     BackupLog[]       @relation("BackupLogUser")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([isActive])
}

model Project {
  id           String               @id @default(cuid())
  key          String               @unique
  name         String
  description  String?
  issueCounter Int                  @default(0)
  members      ProjectMember[]
  sprints      Sprint[]             @relation("ProjectSprints")
  activeSprint Sprint?              @relation("ActiveSprintProject")
  issues       Issue[]
  epics        Epic[]
  auditLogs    AuditLog[]
  backupConfig BackupConfig?
  backups      BackupRecord[]
  backupLogs   BackupLog[]
  jiraConfig   JiraMigrationConfig?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model DirectoryConnection {
  id             String   @id @default(cuid())
  name           String
  host           String
  port           Int      @default(389)
  bindDn         String
  bindPassword   String
  baseDn         String
  userFilter     String   @default("(objectClass=user)")
  loginAttribute String   @default("sAMAccountName")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model JiraMigrationConfig {
  id           String    @id @default(cuid())
  projectId    String    @unique
  jiraUrl      String
  jql          String
  username     String
  token        String
  lastTestedAt DateTime?
  lastSyncedAt DateTime?
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId])
  @@index([updatedAt])
}

model Sprint {
  id              String       @id @default(cuid())
  projectId       String
  activeProjectId String?      @unique
  jiraSprintId    String?      @unique
  name            String
  goal            String?
  status          SprintStatus @default(PLANNED)
  startsAt        DateTime?
  endsAt          DateTime?
  position        Int          @default(0)
  project         Project      @relation("ProjectSprints", fields: [projectId], references: [id], onDelete: Cascade)
  activeProject   Project?     @relation("ActiveSprintProject", fields: [activeProjectId], references: [id], onDelete: SetNull)
  issues          Issue[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId])
  @@index([projectId, status])
}

model Epic {
  id          String   @id @default(cuid())
  projectId   String
  jiraIssueId String?  @unique
  key         String   @unique
  name        String
  description String?
  color       String   @default("#2563eb")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues      Issue[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model Issue {
  id                   String            @id @default(cuid())
  projectId            String
  jiraIssueId          String?           @unique
  sprintId             String?
  epicId               String?
  parentIssueId        String?
  blockedByIssueId     String?
  isBlockedUntilDone   Boolean           @default(false)
  assigneeId           String
  reporterId           String
  code                 String            @unique
  title                String
  description          String?
  type                 IssueType         @default(TASK)
  status               IssueStatus       @default(TODO)
  priority             IssuePriority     @default(MEDIUM)
  estimate             Int?
  timeSpent            Int               @default(0)
  timeRemaining        Int?
  timeSpentDescription String?
  startDate            DateTime          @default(now())
  dueDate              DateTime          @default(now())
  position             Int               @default(0)
  project              Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint               Sprint?           @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  epic                 Epic?             @relation(fields: [epicId], references: [id], onDelete: SetNull)
  parentIssue          Issue?            @relation("IssueSubtasks", fields: [parentIssueId], references: [id], onDelete: SetNull)
  subtasks             Issue[]           @relation("IssueSubtasks")
  blockedByIssue       Issue?            @relation("IssueBlockers", fields: [blockedByIssueId], references: [id], onDelete: SetNull)
  blockingIssues       Issue[]           @relation("IssueBlockers")
  blockers             IssueBlocker[]    @relation("BlockedIssue")
  blockingLinks        IssueBlocker[]    @relation("BlockingIssue")
  assignee             User              @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  reporter             User              @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  labels               IssueLabel[]
  comments             IssueComment[]
  attachments          IssueAttachment[]
  worklogs             IssueWorklog[]
  auditLogs            AuditLog[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([projectId])
  @@index([sprintId])
  @@index([parentIssueId])
  @@index([blockedByIssueId])
  @@index([assigneeId])
  @@index([status])
  @@index([startDate])
  @@index([dueDate])
  @@index([projectId, sprintId], map: "Issue_projectId_sprintId_analytics_idx")
  @@index([projectId, assigneeId], map: "Issue_projectId_assigneeId_analytics_idx")
  @@index([projectId, parentIssueId], map: "Issue_projectId_parentIssueId_analytics_idx")
  @@index([projectId, sprintId, status, position])
}

model IssueBlocker {
  id                  String   @id @default(cuid())
  blockedIssueId      String
  blockerIssueId      String
  isBlockingUntilDone Boolean  @default(false)
  blockedIssue        Issue    @relation("BlockedIssue", fields: [blockedIssueId], references: [id], onDelete: Cascade)
  blockerIssue        Issue    @relation("BlockingIssue", fields: [blockerIssueId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([blockedIssueId, blockerIssueId])
  @@index([blockedIssueId])
  @@index([blockerIssueId])
}

model IssueLabel {
  id        String   @id @default(cuid())
  issueId   String
  name      String
  color     String   @default("#64748b")
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([issueId, name])
  @@index([issueId])
}

model IssueComment {
  id            String   @id @default(cuid())
  issueId       String
  authorId      String
  jiraCommentId String?  @unique
  body          String
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([issueId])
  @@index([authorId])
}

model IssueAttachment {
  id               String   @id @default(cuid())
  issueId          String
  uploaderId       String
  jiraAttachmentId String?  @unique
  name             String
  mimeType         String
  size             Int
  url              String
  storagePath      String
  issue            Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploader         User     @relation(fields: [uploaderId], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([issueId])
  @@index([uploaderId])
}

model IssueWorklog {
  id            String   @id @default(cuid())
  issueId       String
  authorId      String
  jiraWorklogId String?  @unique
  timeSpent     Int
  description   String
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author        User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([issueId])
  @@index([authorId])
  @@index([createdAt])
  @@index([issueId, createdAt], map: "IssueWorklog_issueId_createdAt_analytics_idx")
}

model AuditLog {
  id         String   @id @default(cuid())
  projectId  String
  issueId    String?
  userId     String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue      Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  user       User     @relation("AuditUser", fields: [userId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([issueId])
  @@index([userId])
  @@index([entityType, entityId])
}

model BackupConfig {
  id                String          @id @default(cuid())
  projectId         String          @unique
  storagePath       String
  scheduleEnabled   Boolean         @default(false)
  frequency         BackupFrequency @default(DAILY)
  runAt             String          @default("02:00")
  dayOfWeek         Int?
  dayOfMonth        Int?
  retentionMaxCount Int             @default(10)
  retentionMaxDays  Int?
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([scheduleEnabled])
  @@index([nextRunAt])
}

model BackupRecord {
  id            String       @id @default(cuid())
  projectId     String
  fileName      String
  filePath      String
  storagePath   String
  type          BackupType
  status        BackupStatus @default(PENDING)
  sizeBytes     Int?
  checksum      String?
  manifest      Json?
  generatedById String?
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  errorMessage  String?
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generatedBy   User?        @relation("BackupGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  logs          BackupLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([fileName])
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model BackupLog {
  id        String        @id @default(cuid())
  backupId  String?
  projectId String
  userId    String?
  action    String
  level     String        @default("info")
  message   String
  details   Json?
  backup    BackupRecord? @relation(fields: [backupId], references: [id], onDelete: SetNull)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User?         @relation("BackupLogUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([backupId])
  @@index([projectId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
